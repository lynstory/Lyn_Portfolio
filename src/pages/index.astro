---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const base = import.meta.env.BASE_URL;

// 대표 Projects 3개: featured=true + date desc (ROADMAP §7.2)
const allProjects = await getCollection("projects", ({ data }) => data.featured && !data.draft);
const featuredProjects = allProjects
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const hashtags = ["#문제해결", "#동기설계", "#0→1 실행", "#국제협업", "#AI기반기획"];
---

<BaseLayout title="Home" description="PM 직무 어필 포트폴리오 — 다양한 도메인에서 문제 정의·기획·실행을 경험한 제너럴리스트.">

  <!-- Hero -->
  <section class="bg-(--color-bg-warm)">
  <div class="max-w-5xl mx-auto px-6 pt-16 pb-20 md:pt-20 md:pb-28">
    <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-16">

      <!-- 좌측: 텍스트 블록 -->
      <div class="flex-1 text-center md:text-left">
        <p class="hero-anim text-sm font-medium text-gray-400 tracking-widest uppercase mb-6" style="animation-delay: 0ms">
          PM 지향 &middot; 국제 협업 &middot; 사업 경험 &middot; AI 기반 기획
        </p>
        <h1
          class="hero-anim text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-[1.08] tracking-tight mb-6"
          style="animation-delay: 80ms"
        >
          문제를 정의하고<br />해결하는 기획자
        </h1>
        <p
          class="hero-anim text-base md:text-lg text-gray-500 leading-relaxed max-w-md mx-auto md:mx-0 mb-10"
          style="animation-delay: 160ms"
        >
          다양한 도메인에서 문제를 정의하고 기획·실행해온 제너럴리스트.<br class="hidden md:block" />
          사람과 맥락을 먼저 이해하고, 실행으로 연결합니다.
        </p>

        <!-- CTA 버튼 -->
        <div
          class="hero-anim flex flex-col sm:flex-row gap-3 justify-center md:justify-start"
          style="animation-delay: 240ms"
        >
          <a
            href={`${base}projects`}
            class="px-6 py-3 bg-gray-900 text-white font-medium rounded-md hover:bg-gray-700 transition-colors text-sm text-center"
          >
            프로젝트 보기
          </a>
          <a
            href={`${base}resume.pdf`}
            download
            class="px-6 py-3 border border-gray-900 text-gray-900 font-medium rounded-md hover:bg-gray-50 transition-colors text-sm text-center"
          >
            이력서 다운로드
          </a>
        </div>
      </div>

      <!-- 우측: 프로필 사진 (직사각형) -->
      <div class="hero-anim shrink-0" style="animation-delay: 120ms">
        <div class="w-56 md:w-72 lg:w-80 aspect-[3/4] rounded-2xl overflow-hidden bg-gray-100">
          <img
            src={`${base}Home-profile.png`}
            alt="프로필 사진"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
  </section>

  <!-- Selected Projects -->
  <section class="fade-in-up max-w-5xl mx-auto px-6 pb-24">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-xl font-bold text-gray-900">Selected Projects</h2>
      <a
        href={`${base}projects`}
        class="text-sm text-gray-500 hover:text-gray-900 transition-colors flex items-center gap-1"
      >
        전체 프로젝트 보기 <span aria-hidden="true">→</span>
      </a>
    </div>

    {featuredProjects.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
        {featuredProjects.map((entry) => <ProjectCard entry={entry} />)}
      </div>
    ) : (
      <p class="text-sm text-gray-400">프로젝트를 준비 중입니다.</p>
    )}
  </section>

  <!-- About Me -->
  <section class="fade-in-up bg-(--color-bg-warm-deep) py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-xl font-bold text-gray-900 mb-5">About Me</h2>
      <p class="text-gray-600 leading-relaxed max-w-lg mb-8">
        새로운 환경에도 빠르게 적응하고,<br />
        다양한 협업을 통해 현실의 문제를 기획으로 풀어냅니다.
      </p>

      <!-- 해시태그 칩 -->
      <div class="flex flex-wrap gap-2.5 mb-10">
        {hashtags.map((tag) => (
          <span class="inline-flex items-center px-3 py-1.5 bg-(--color-bg-warm) border border-[#D9D0C5] rounded-full text-sm text-gray-600 font-medium">
            {tag}
          </span>
        ))}
      </div>

      <a
        href={`${base}about`}
        class="text-sm font-medium text-gray-900 hover:text-gray-500 transition-colors flex items-center gap-1 w-fit"
      >
        더 알아보기 <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

</BaseLayout>
