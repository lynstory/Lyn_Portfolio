---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

// ROADMAP §2.2 Home — 핵심 키워드
const keywords = ["PM 지원자", "국제 협업", "사업 경험", "AI 기반 기획"];

// 대표 Projects 3개: Content Collections에서 featured=true + date desc (ROADMAP §7.2)
const allProjects = await getCollection("projects", ({ data }) => data.featured && !data.draft);
const featuredProjects = allProjects
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Home" description="PM 직무 어필 포트폴리오 — 다양한 도메인에서 문제 정의·기획·실행을 경험한 제너럴리스트.">

  <!-- Hero: 좌측 텍스트 + 우측 프로필 사진 (ROADMAP §2.2 Home) -->
  <!-- 모바일: 위(사진) → 아래(텍스트) 스택 배치 -->
  <div class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 pointer-events-none bg-[radial-gradient(ellipse_at_top,_rgba(59,91,169,0.08),_transparent_60%)]"
    ></div>
  <section class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="flex flex-col-reverse md:flex-row items-center gap-12 md:gap-20">

      <!-- 좌측: 텍스트 블록 (모바일에선 하단) -->
      <div class="flex-1 text-center md:text-left">
        <!-- TODO: 한 줄 정체성 확정 후 업데이트 (ROADMAP §1.1) -->
        <h1 class="hero-anim text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-5" style="animation-delay: 0ms">
          문제를 정의하고<br />해결하는 기획자
        </h1>

        <!-- TODO: 서브카피 작성 (ROADMAP §1.4 핵심 메시지 기반) -->
        <p class="hero-anim text-lg text-gray-500 mb-10 leading-relaxed max-w-md mx-auto md:mx-0" style="animation-delay: 120ms">
          다양한 도메인에서 문제 정의·기획·실행을 경험한 제너럴리스트.
          국제 협업, 공공 R&D, 지역 사회 문제, 본인 사업 운영을 거치며
          현실 문제를 정의하고 해결하는 한 가지 동작을 반복해 왔습니다.
        </p>

        <!-- CTA 버튼 2개 (ROADMAP §2.2 Home) -->
        <div class="hero-anim flex flex-col sm:flex-row gap-4 justify-center md:justify-start" style="animation-delay: 240ms">
          <a
            href="/projects"
            class="px-6 py-3 bg-accent text-white font-medium rounded-lg hover:opacity-90 transition-opacity text-center text-sm"
          >
            Projects 보기
          </a>
          <a
            href="/resume.pdf"
            download
            class="px-6 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:border-accent hover:text-accent transition-colors text-center text-sm"
          >
            Resume 다운로드
          </a>
        </div>
      </div>

      <!-- 우측: 프로필 사진 (모바일에선 상단) -->
      <!-- 프로필 사진은 사용자가 /public/profile.jpg에 배치 완료 (CLAUDE.md §4) -->
      <div class="hero-anim flex-shrink-0" style="animation-delay: 360ms">
        <img
          src="/profile.jpg"
          alt="프로필 사진"
          class="w-44 h-44 md:w-60 md:h-60 rounded-full object-cover border-4 border-gray-100 shadow-sm"
        />
      </div>
    </div>
  </section>
  </div>

  <!-- 핵심 키워드 칩 (ROADMAP §2.2 Home) -->
  <section class="fade-in-up max-w-5xl mx-auto px-6 pb-20">
    <div class="flex flex-wrap gap-3 justify-center md:justify-start">
      {keywords.map((kw) => (
        <span class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-full text-sm font-medium text-gray-600">
          {kw}
        </span>
      ))}
    </div>
  </section>

  <!-- 대표 Projects 3개 미리보기 (Content Collections에서 자동 로드 — ROADMAP §2.2 Home, §7.2) -->
  <section class="fade-in-up max-w-5xl mx-auto px-6 pb-24">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">대표 프로젝트</h2>
    {featuredProjects.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {featuredProjects.map((entry) => <ProjectCard entry={entry} />)}
      </div>
    ) : (
      <p class="text-sm text-gray-400">프로젝트를 준비 중입니다.</p>
    )}
    <div class="mt-8 text-center md:text-left">
      <a href="/projects" class="text-sm font-medium text-accent hover:underline">
        모든 프로젝트 보기 →
      </a>
    </div>
  </section>

  <!-- About / Contact 동선 안내 (ROADMAP §2.2 Home) -->
  <section class="fade-in-up bg-gray-50 py-16">
    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row gap-8 items-center justify-between">
      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">더 알고 싶으신가요?</h2>
        <p class="text-gray-500 text-sm">배경·성장 이야기를 담은 About을 만나보세요.</p>
      </div>
      <div class="flex gap-4">
        <a
          href="/about"
          class="px-5 py-2.5 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:border-accent hover:text-accent transition-colors"
        >
          About
        </a>
        <a
          href="/contact"
          class="px-5 py-2.5 bg-accent text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity"
        >
          Contact
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
