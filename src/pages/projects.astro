---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const base = import.meta.env.BASE_URL;
const filterTabs = ["전체", "기획", "공공·정책", "임팩트", "AI", "브랜딩"] as const;

const allProjects = await getCollection("projects", ({ data }) => !data.draft);

// Featured 카드: highlight=true 우선, 없으면 최신순 첫 번째
const highlightedProject =
  allProjects.find((p) => p.data.highlight) ??
  allProjects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

// Selected Projects: featured인 것 최신순
const selectedProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Projects"
  description="문제를 정의하고 해결한 과정을 담은 PM 직무 어필 케이스 스터디."
  hideFooter={true}
>

  <!-- 1. Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-14 pb-10">
    <p class="text-xs font-medium tracking-widest text-gray-400 uppercase mb-6">Projects</p>
    <div class="flex flex-col md:flex-row md:items-start gap-8 md:gap-16">
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 leading-[1.08] tracking-tight shrink-0">
        문제를 발견하고<br />기획하고<br />직접 실행한 프로젝트들
      </h1>
      <p class="text-sm md:text-base text-gray-500 leading-relaxed pt-1 max-w-xs">
        기획자로서 문제를 정의하고, 사람의 동기를 설계하며,<br />
        직접 실행까지 이어간 프로젝트들을 모았습니다.<br />
        작은 실험부터 공공·임팩트 프로젝트까지,<br />
        실행 가능한 기획으로 변화를 만들어납니다.
      </p>
    </div>
  </section>

  <!-- 2. Filter Tabs -->
  <div class="max-w-5xl mx-auto px-6 mb-8">
    <div class="flex flex-wrap gap-2">
      {filterTabs.map((tab, i) => (
        <button
          data-filter={tab}
          class={`px-4 py-1.5 rounded-full text-sm font-medium transition-colors ${
            i === 0
              ? "bg-gray-900 text-white"
              : "bg-white border border-gray-200 text-gray-600 hover:border-gray-400"
          }`}
        >
          {tab}
        </button>
      ))}
    </div>
  </div>

  <!-- 3. Featured Card -->
  {highlightedProject && (
    <section class="fade-in-up max-w-5xl mx-auto px-6 mb-14">
      <div class="bg-gray-50 rounded-2xl p-8 md:p-12 flex flex-col md:flex-row gap-10 border border-gray-100">
        <!-- 좌: 텍스트 -->
        <div class="flex-1 flex flex-col justify-between min-w-0">
          <div>
            <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase mb-4">Featured</p>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4 leading-snug">
              {highlightedProject.data.title}
            </h2>
            <p class="text-sm text-gray-500 leading-relaxed mb-8 max-w-sm">
              {highlightedProject.data.summary}
            </p>
            <!-- 메타 테이블 -->
            <dl class="space-y-2 mb-8 text-sm">
              {highlightedProject.data.role && (
                <div class="flex gap-6">
                  <dt class="w-20 text-gray-400 shrink-0">Role</dt>
                  <dd class="text-gray-700">{highlightedProject.data.role}</dd>
                </div>
              )}
              <div class="flex gap-6">
                <dt class="w-20 text-gray-400 shrink-0">Period</dt>
                <dd class="text-gray-700">{highlightedProject.data.period}</dd>
              </div>
              {highlightedProject.data.tags.length > 0 && (
                <div class="flex gap-6">
                  <dt class="w-20 text-gray-400 shrink-0">Keywords</dt>
                  <dd class="text-gray-700">{highlightedProject.data.tags.join(' · ')}</dd>
                </div>
              )}
            </dl>
          </div>
          <a
            href={`${base}projects/${highlightedProject.id}`}
            class="inline-flex items-center gap-2 px-5 py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors w-fit"
          >
            자세히 보기 <span aria-hidden="true">→</span>
          </a>
        </div>
        <!-- 우: 이미지 -->
        <div class="md:w-[46%] shrink-0">
          <div class="aspect-[4/3] rounded-xl overflow-hidden bg-gradient-to-br from-violet-50 to-purple-100">
            {highlightedProject.data.image && (
              <img
                src={`${base}projects/${highlightedProject.data.image}`}
                alt={highlightedProject.data.title}
                class="w-full h-full object-cover"
              />
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 4. Selected Projects -->
  <section class="fade-in-up max-w-5xl mx-auto px-6 mb-14">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-base font-bold text-gray-900">Selected Projects</h2>
      <a
        href="#"
        class="text-sm text-gray-500 hover:text-gray-900 transition-colors flex items-center gap-1"
      >
        전체 프로젝트 보기 <span aria-hidden="true">→</span>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
      {selectedProjects.map((entry) => (
        <div data-cat={entry.data.category}>
          <ProjectCard entry={entry} />
        </div>
      ))}
    </div>
  </section>

  <!-- 5. How I approached projects -->
  <section class="fade-in-up max-w-5xl mx-auto px-6 mb-14">
    <h2 class="text-base font-bold text-gray-900 mb-6">How I approached projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <!-- 문제 정의 -->
      <div class="border border-gray-200 rounded-xl p-6 flex items-center gap-4 bg-white">
        <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="white" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-0.5">문제 정의</p>
          <p class="text-sm text-gray-500 leading-snug">사용자의 맥락과<br />진짜 문제를 파고듦</p>
        </div>
      </div>

      <!-- 동기 설계 -->
      <div class="border border-gray-200 rounded-xl p-6 flex items-center gap-4 bg-white">
        <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-5 h-5">
            <circle cx="15.5" cy="5"  r="2.5" stroke="white" stroke-width="1.8"/>
            <circle cx="8.5"  cy="12" r="2.5" stroke="white" stroke-width="1.8"/>
            <circle cx="15.5" cy="19" r="2.5" stroke="white" stroke-width="1.8"/>
            <line x1="13.7" y1="6.8"  x2="10.3" y2="10.2" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
            <line x1="10.3" y1="13.8" x2="13.7" y2="17.2" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-0.5">동기 설계</p>
          <p class="text-sm text-gray-500 leading-snug">사람이 움직일 흐름과<br />참여 구조 설계</p>
        </div>
      </div>

      <!-- 실행과 검증 -->
      <div class="border border-gray-200 rounded-xl p-6 flex items-center gap-4 bg-white">
        <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="white" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84" />
          </svg>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-0.5">실행과 검증</p>
          <p class="text-sm text-gray-500 leading-snug">작게라도 빠르게<br />만들어 보고 개선</p>
        </div>
      </div>

    </div>
  </section>

  <!-- 6. 더 많은 프로젝트 -->
  <section class="fade-in-up max-w-5xl mx-auto px-6 mb-20">
    <h2 class="text-base font-bold text-gray-900 mb-6">더 많은 프로젝트</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">

      <a href={`${base}side-quests/moojigaeng`} class="flex items-center gap-4 border border-gray-200 rounded-xl p-4 bg-white hover:border-gray-400 transition-colors group">
        <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="w-5 h-5 text-gray-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21c-4.418 0-8-2.239-8-5 0-1.524 1.023-2.894 2.666-3.87M12 21c4.418 0 8-2.239 8-5 0-1.524-1.023-2.894-2.666-3.87M12 21V9m0 0c0-2.21-1.343-4-3-4S6 6.79 6 9m6 0c0-2.21 1.343-4 3-4s3 1.79 3 4M6.5 5.5C6.5 4.12 7.12 3 8 3s1.5 1.12 1.5 2.5M17.5 5.5C17.5 4.12 16.88 3 16 3s-1.5 1.12-1.5 2.5" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-gray-900 text-sm">무지개냥</p>
          <p class="text-xs text-gray-500 truncate">반려동물 커뮤니티 서비스 기획</p>
        </div>
        <div class="flex items-center gap-1.5 shrink-0 text-sm text-gray-400">
          <span>2023</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </div>
      </a>

      <a href="#" class="flex items-center gap-4 border border-gray-200 rounded-xl p-4 bg-white hover:border-gray-400 transition-colors group">
        <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="w-5 h-5 text-gray-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-gray-900 text-sm">AI 기반 PM 실험</p>
          <p class="text-xs text-gray-500 truncate">AI 도구 활용 PM 워크플로우 실험</p>
        </div>
        <div class="flex items-center gap-1.5 shrink-0 text-sm text-gray-400">
          <span>2024</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </div>
      </a>

      <a href={`${base}side-quests`} class="flex items-center gap-4 border border-gray-200 rounded-xl p-4 bg-white hover:border-gray-400 transition-colors group">
        <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="w-5 h-5 text-gray-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-gray-900 text-sm">사이드 퀘스트</p>
          <p class="text-xs text-gray-500 truncate">작은 실험으로 시작한 문제 해결 프로젝트</p>
        </div>
        <div class="flex items-center gap-1.5 shrink-0 text-sm text-gray-400">
          <span>2022</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </div>
      </a>

      <a href="#" class="flex items-center gap-4 border border-gray-200 rounded-xl p-4 bg-white hover:border-gray-400 transition-colors group">
        <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="w-5 h-5 text-gray-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-gray-900 text-sm">0→1 실험</p>
          <p class="text-xs text-gray-500 truncate">좋은 아이디어는 작게라도 굴려봄</p>
        </div>
        <div class="flex items-center gap-1.5 shrink-0 text-sm text-gray-400">
          <span>2023</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </div>
      </a>

    </div>
  </section>

  <!-- 7. Dark CTA Footer -->
  <div class="bg-[#1a1a1a] text-white">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-10">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold leading-snug mb-2">
            더 많은 작업과 실험이<br />궁금하다면
          </h2>
          <p class="text-sm text-gray-400">프로젝트 상세와 사이드 퀘스트도 이어서 만나보세요.</p>
        </div>
        <div class="flex items-center gap-5 flex-wrap">
          <a href="mailto:lyn357abc@gmail.com" class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            Email
          </a>
          <a href="https://github.com/lynstory" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            GitHub
          </a>
          <a href="#" class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors" aria-label="LinkedIn (준비 중)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a
            href={`${base}side-quests`}
            class="w-10 h-10 rounded-full border border-white/40 flex items-center justify-center hover:bg-white hover:text-gray-900 transition-colors shrink-0"
            aria-label="Side Quests로 이동"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const wrappers = document.querySelectorAll<HTMLElement>('[data-cat]');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const f = tab.dataset.filter ?? '전체';
        tabs.forEach((t) => {
          t.classList.remove('bg-gray-900', 'text-white');
          t.classList.add('bg-white', 'border', 'border-gray-200', 'text-gray-600');
        });
        tab.classList.remove('bg-white', 'border', 'border-gray-200', 'text-gray-600');
        tab.classList.add('bg-gray-900', 'text-white');
        wrappers.forEach((w) => {
          w.classList.toggle('hidden', f !== '전체' && w.dataset.cat !== f);
        });
      });
    });
  </script>

</BaseLayout>
