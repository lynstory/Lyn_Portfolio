---
// ROADMAP §2.2 Experience — 시간순 타임라인 (2018~현재)
// Phase 2: Content Collections 기반으로 자동화 (src/content/experience/*.mdx)
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ExperienceItem from "../components/ExperienceItem.astro";

const categories = ["학교/학술", "동아리/대외활동", "국제 활동", "인턴/실무", "교육과정"] as const;

const allExp = await getCollection("experience");

// order asc 정렬 (1=최신이 위)
const sorted = allExp.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Experience" description="2018년부터 현재까지의 학습·활동·실무 경험 타임라인.">
  <div class="max-w-3xl mx-auto px-6 py-20">

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">Experience</h1>
    <p class="text-gray-500 mb-10 text-sm leading-relaxed">
      2018년부터 현재까지의 활동·실무 경험을 시간순으로 정리했습니다.
    </p>

    <!-- 카테고리 태그 (클릭 필터) -->
    <div class="flex flex-wrap gap-2 mb-14">
      <button
        data-filter="전체"
        class="px-3 py-1 rounded-full text-xs font-medium transition-colors cursor-pointer bg-accent text-white"
      >
        전체
      </button>
      {categories.map((cat) => (
        <button
          data-filter={cat}
          class="px-3 py-1 bg-gray-100 rounded-full text-xs font-medium text-gray-500 hover:bg-gray-200 transition-colors cursor-pointer"
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- 타임라인 -->
    <ol id="exp-list" class="fade-in-up relative border-l border-gray-200 space-y-10 list-none m-0 p-0">
      {sorted.map((entry) => <ExperienceItem entry={entry} />)}
    </ol>

  </div>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('#exp-list [data-category]');
  let active: string | null = null;

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.filter!;

      if (cat === '전체' || active === cat) {
        active = null;
        items.forEach(item => item.classList.remove('hidden'));
        filterBtns.forEach(b => b.dataset.filter === '전체' ? activateBtn(b) : resetBtn(b));
      } else {
        active = cat;
        items.forEach(item => {
          item.classList.toggle('hidden', item.dataset.category !== cat);
        });
        filterBtns.forEach(b => {
          b.dataset.filter === cat ? activateBtn(b) : resetBtn(b);
        });
      }
    });
  });

  function activateBtn(btn: HTMLButtonElement) {
    btn.classList.add('bg-accent', 'text-white');
    btn.classList.remove('bg-gray-100', 'text-gray-500', 'hover:bg-gray-200');
  }
  function resetBtn(btn: HTMLButtonElement) {
    btn.classList.remove('bg-accent', 'text-white');
    btn.classList.add('bg-gray-100', 'text-gray-500', 'hover:bg-gray-200');
  }
</script>
