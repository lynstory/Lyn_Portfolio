---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ExperienceItem from "../components/ExperienceItem.astro";

const categories = ["학교/학술", "동아리/대외활동", "국제 활동", "인턴/실무", "교육과정"] as const;

const allExp = await getCollection("experience");
const sorted = allExp.sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Experience" description="다양한 경험을 통해 성장해왔습니다.">
  <div class="max-w-3xl mx-auto px-6 pt-8 pb-20">

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">Experience</h1>
    <p class="text-gray-500 mb-5 text-sm leading-relaxed">
      다양한 경험을 통해 성장해왔습니다.
    </p>

    <!-- 카테고리 필터 버튼 -->
    <div class="flex flex-wrap gap-2 mb-6">
      <button
        data-filter="전체"
        class="px-3 py-1 rounded-full text-xs font-medium transition-colors cursor-pointer bg-gray-900 text-white"
      >
        전체
      </button>
      {categories.map((cat) => (
        <button
          data-filter={cat}
          class="px-3 py-1 bg-[#F0EBE3] rounded-full text-xs font-medium text-gray-600 hover:bg-[#E5DDD4] transition-colors cursor-pointer"
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- 타임라인 -->
    <div class="relative">
      <!-- 세로선: 모바일 left=0.5rem, 데스크탑 left=8.5rem -->
      <div class="absolute top-0 bottom-0 w-px bg-gray-200 left-[0.5rem] sm:left-[8.5rem]"></div>
      <ol id="exp-list" class="space-y-6 list-none m-0 p-0">
        {sorted.map((entry) => <ExperienceItem entry={entry} />)}
      </ol>
    </div>

  </div>

  <!-- Quote 섹션 -->
  <section class="fade-in-up max-w-3xl mx-auto px-6 py-8 pb-14">
    <div class="bg-(--color-bg-warm) rounded-2xl p-8 md:p-10 flex items-center gap-6 md:gap-8">
      <div class="text-6xl md:text-7xl font-serif text-[#B8A898] leading-none shrink-0 select-none">&ldquo;</div>
      <p class="text-base md:text-lg font-medium text-gray-900 leading-relaxed">
        다양한 경험은 문제를 더 넓게 보고, 사람과 함께 더 나은 해결책을 찾는 힘이 되었습니다.
      </p>
    </div>
  </section>

</BaseLayout>

<!-- Blender/UE5 영상 캐러셀 모달 -->
<dialog
  id="blender-ue5-modal"
  class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-0 bg-transparent backdrop:bg-black/60 w-[92vw] sm:w-[96vw] max-w-4xl"
  aria-label="개인 프로젝트 영상"
>
  <div class="relative">
    <!-- 흰 카드: 데스크탑은 양옆 mx-14로 화살표 공간 확보 -->
    <div class="relative bg-white rounded-2xl overflow-hidden sm:mx-14">
      <button
        type="button"
        data-modal-close
        aria-label="닫기"
        class="absolute top-3 right-3 z-10 w-8 h-8 flex items-center justify-center rounded-full bg-white/90 hover:bg-white text-gray-700 cursor-pointer"
      >✕</button>

      <div data-carousel-viewport class="overflow-hidden touch-pan-y">
        <div data-carousel-track class="flex transition-transform duration-300 ease-out">
          <div class="w-full shrink-0 aspect-video bg-black">
            <iframe data-modal-iframe data-video-id="IpsGFjavhq0" src="" title="개인 프로젝트1" class="w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
          <div class="w-full shrink-0 aspect-video bg-black">
            <iframe data-modal-iframe data-video-id="5-oH4xFLu-o" src="" title="개인 프로젝트2" class="w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
          <div class="w-full shrink-0 aspect-video bg-black">
            <iframe data-modal-iframe data-video-id="fr4TIXOXnZw" src="" title="3D 툴 활용" class="w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </div>

    <!-- 데스크탑 화살표 (sm 이상): 카드 양옆 absolute -->
    <button type="button" data-carousel-prev aria-label="이전 영상"
      class="hidden sm:flex absolute left-0 top-1/2 -translate-y-1/2 w-12 h-12 items-center justify-center rounded-full bg-white/15 hover:bg-white/25 transition-colors cursor-pointer">
      <span class="block w-0 h-0 border-y-[8px] border-y-transparent border-r-[12px] border-r-white ml-[-2px]"></span>
    </button>
    <button type="button" data-carousel-next aria-label="다음 영상"
      class="hidden sm:flex absolute right-0 top-1/2 -translate-y-1/2 w-12 h-12 items-center justify-center rounded-full bg-white/15 hover:bg-white/25 transition-colors cursor-pointer">
      <span class="block w-0 h-0 border-y-[8px] border-y-transparent border-l-[12px] border-l-white ml-[2px]"></span>
    </button>

    <!-- 모바일 화살표 (sm 미만): 카드 아래 row -->
    <div class="flex sm:hidden justify-center gap-8 mt-4">
      <button type="button" data-carousel-prev aria-label="이전 영상"
        class="w-10 h-10 flex items-center justify-center rounded-full bg-white/15 hover:bg-white/25 transition-colors cursor-pointer">
        <span class="block w-0 h-0 border-y-[8px] border-y-transparent border-r-[12px] border-r-white ml-[-2px]"></span>
      </button>
      <button type="button" data-carousel-next aria-label="다음 영상"
        class="w-10 h-10 flex items-center justify-center rounded-full bg-white/15 hover:bg-white/25 transition-colors cursor-pointer">
        <span class="block w-0 h-0 border-y-[8px] border-y-transparent border-l-[12px] border-l-white ml-[2px]"></span>
      </button>
    </div>
  </div>
</dialog>

<!-- APYE 영상 모달 -->
<dialog
  id="apye-modal"
  class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-0 bg-transparent backdrop:bg-black/60 w-[92vw] sm:w-[96vw] max-w-4xl"
  aria-label="APYE 활동 영상"
>
  <div class="relative bg-white rounded-2xl overflow-hidden">
    <button
      type="button"
      data-apye-close
      aria-label="닫기"
      class="absolute top-3 right-3 z-10 w-8 h-8 flex items-center justify-center rounded-full bg-white/90 hover:bg-white text-gray-700 cursor-pointer"
    >✕</button>
    <div class="aspect-video bg-black">
      <iframe
        data-apye-iframe
        src=""
        title="APYE 활동 영상"
        class="w-full h-full"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</dialog>

<!-- 국토대장정 활동 사진 모달 -->
<dialog
  id="nationwide-walk-modal"
  class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-0 bg-transparent backdrop:bg-black/60 w-[92vw] sm:w-[96vw] max-w-4xl"
  aria-label="국토대장정 활동 사진"
>
  <div class="relative bg-white rounded-2xl overflow-hidden max-h-[90vh] flex flex-col">
    <button
      type="button"
      data-nw-close
      aria-label="닫기"
      class="absolute top-3 right-3 z-20 w-8 h-8 flex items-center justify-center rounded-full bg-white/90 hover:bg-white text-gray-700 cursor-pointer shadow"
    >✕</button>
    <div class="overflow-y-auto p-4 sm:p-6">
      <div class="grid grid-cols-3 gap-2 sm:gap-3">
        {Array.from({ length: 10 }, (_, i) => i + 1).map((n) => (
          <div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
            <img
              src={`${base}experience/nationwide-walk/${n}.png`}
              alt={`국토대장정 활동 사진 ${n}`}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</dialog>

<!-- 휴먼-생태분석 연구실 안내 모달 -->
<dialog
  id="heal-lab-modal"
  class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-0 bg-transparent backdrop:bg-black/60 w-[92vw] max-w-md"
  aria-label="휴먼-생태분석 연구실 안내"
>
  <div class="relative bg-white rounded-2xl p-6 sm:p-8">
    <button
      type="button"
      data-heal-lab-close
      aria-label="닫기"
      class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full bg-white/90 hover:bg-gray-100 text-gray-700 cursor-pointer"
    >✕</button>
    <h3 class="text-lg font-bold text-gray-900 mb-2 pr-8">한양대학교 휴먼-생태분석 연구실</h3>
    <p class="text-xs text-gray-500 mb-1">공식 웹사이트</p>
    <p class="text-sm text-gray-600 break-all mb-5">http://heal.hanyang.ac.kr/</p>
    <a
      href="http://heal.hanyang.ac.kr/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-full hover:bg-gray-700 transition-colors"
    >
      사이트 방문하기
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</dialog>

<!-- 한양대학교 홈페이지 안내 모달 -->
<dialog
  id="hanyang-major-modal"
  class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-0 bg-transparent backdrop:bg-black/60 w-[92vw] max-w-md"
  aria-label="한양대학교 홈페이지 안내"
>
  <div class="relative bg-white rounded-2xl p-6 sm:p-8">
    <button
      type="button"
      data-hanyang-major-close
      aria-label="닫기"
      class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full bg-white/90 hover:bg-gray-100 text-gray-700 cursor-pointer"
    >✕</button>
    <h3 class="text-lg font-bold text-gray-900 mb-2 pr-8">한양대학교</h3>
    <p class="text-xs text-gray-500 mb-1">공식 웹사이트</p>
    <p class="text-sm text-gray-600 break-all mb-5">https://www.hanyang.ac.kr/web/www</p>
    <a
      href="https://www.hanyang.ac.kr/web/www"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-full hover:bg-gray-700 transition-colors"
    >
      사이트 방문하기
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</dialog>

<!-- OVAL KOREA 지부 안내 모달 -->
<dialog
  id="oval-modal"
  class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-0 bg-transparent backdrop:bg-black/60 w-[92vw] max-w-md"
  aria-label="OVAL 지부 안내"
>
  <div class="relative bg-white rounded-2xl p-6 sm:p-8">
    <button
      type="button"
      data-oval-close
      aria-label="닫기"
      class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full bg-white/90 hover:bg-gray-100 text-gray-700 cursor-pointer"
    >✕</button>
    <h3 data-oval-name class="text-lg font-bold text-gray-900 mb-2 pr-8"></h3>
    <p data-oval-channel class="text-xs text-gray-500 mb-1"></p>
    <p data-oval-url class="text-sm text-gray-600 break-all mb-5"></p>
    <a
      data-oval-link
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-full hover:bg-gray-700 transition-colors"
    >
      사이트 방문하기
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</dialog>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('#exp-list [data-category]');
  let active: string | null = null;

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.filter!;

      if (cat === '전체' || active === cat) {
        active = null;
        items.forEach(item => item.classList.remove('hidden'));
        filterBtns.forEach(b => b.dataset.filter === '전체' ? activateBtn(b) : resetBtn(b));
      } else {
        active = cat;
        items.forEach(item => {
          item.classList.toggle('hidden', item.dataset.category !== cat);
        });
        filterBtns.forEach(b => {
          b.dataset.filter === cat ? activateBtn(b) : resetBtn(b);
        });
      }
    });
  });

  function activateBtn(btn: HTMLButtonElement) {
    btn.classList.add('bg-gray-900', 'text-white');
    btn.classList.remove('bg-[#F0EBE3]', 'text-gray-600', 'hover:bg-[#E5DDD4]');
  }
  function resetBtn(btn: HTMLButtonElement) {
    btn.classList.remove('bg-gray-900', 'text-white');
    btn.classList.add('bg-[#F0EBE3]', 'text-gray-600', 'hover:bg-[#E5DDD4]');
  }

  // 캐러셀 모달 제어
  const modal = document.getElementById('blender-ue5-modal') as HTMLDialogElement | null;
  const track = modal?.querySelector<HTMLElement>('[data-carousel-track]') ?? null;
  const viewport = modal?.querySelector<HTMLElement>('[data-carousel-viewport]') ?? null;
  const iframes = Array.from(modal?.querySelectorAll<HTMLIFrameElement>('[data-modal-iframe]') ?? []);
  const prevBtns = Array.from(modal?.querySelectorAll<HTMLButtonElement>('[data-carousel-prev]') ?? []);
  const nextBtns = Array.from(modal?.querySelectorAll<HTMLButtonElement>('[data-carousel-next]') ?? []);
  const slideIds = iframes.map(f => f.dataset.videoId ?? '');
  let current = 0;

  const buildSrc = (id: string) => `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;

  function updateArrows() {
    prevBtns.forEach(b => b.classList.toggle('invisible', current === 0));
    nextBtns.forEach(b => b.classList.toggle('invisible', current === slideIds.length - 1));
  }

  function positionTrack(animate: boolean) {
    if (!track) return;
    track.style.transition = animate ? '' : 'none';
    track.style.transform = `translateX(-${current * 100}%)`;
    if (!animate) {
      void track.offsetHeight;
      track.style.transition = '';
    }
  }

  function goTo(idx: number) {
    if (idx < 0 || idx >= slideIds.length || idx === current) return;
    const prev = current;
    current = idx;
    if (iframes[idx]) iframes[idx].src = buildSrc(slideIds[idx]);
    positionTrack(true);
    setTimeout(() => { if (iframes[prev]) iframes[prev].src = ''; }, 320);
    updateArrows();
  }

  document.querySelectorAll<HTMLButtonElement>('[data-modal-open="blender-ue5"]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!modal) return;
      const idx = slideIds.indexOf(btn.dataset.videoId ?? '');
      if (idx < 0) return;
      iframes.forEach((f, i) => { f.src = i === idx ? buildSrc(slideIds[i]) : ''; });
      current = idx;
      positionTrack(false);
      updateArrows();
      modal.showModal();
    });
  });

  prevBtns.forEach(b => b.addEventListener('click', () => goTo(current - 1)));
  nextBtns.forEach(b => b.addEventListener('click', () => goTo(current + 1)));

  // 스와이프 (pointer = touch + mouse 통합)
  let startX: number | null = null;
  const THRESHOLD = 50;
  viewport?.addEventListener('pointerdown', (e) => { startX = e.clientX; });
  viewport?.addEventListener('pointerup', (e) => {
    if (startX === null) return;
    const dx = e.clientX - startX;
    startX = null;
    if (Math.abs(dx) < THRESHOLD) return;
    if (dx < 0) goTo(current + 1);
    else goTo(current - 1);
  });
  viewport?.addEventListener('pointercancel', () => { startX = null; });

  modal?.querySelector('[data-modal-close]')?.addEventListener('click', () => modal.close());
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
  modal?.addEventListener('close', () => { iframes.forEach(f => f.src = ''); });

  // APYE 단일 영상 모달
  const apyeModal = document.getElementById('apye-modal') as HTMLDialogElement | null;
  const apyeIframe = apyeModal?.querySelector<HTMLIFrameElement>('[data-apye-iframe]') ?? null;
  const APYE_SRC = 'https://www.youtube.com/embed/x2HKjpZpkZk?autoplay=1&rel=0';

  document.querySelectorAll<HTMLButtonElement>('[data-modal-open="apye"]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!apyeModal || !apyeIframe) return;
      apyeIframe.src = APYE_SRC;
      apyeModal.showModal();
    });
  });

  apyeModal?.querySelector('[data-apye-close]')?.addEventListener('click', () => apyeModal.close());
  apyeModal?.addEventListener('click', (e) => { if (e.target === apyeModal) apyeModal.close(); });
  apyeModal?.addEventListener('close', () => { if (apyeIframe) apyeIframe.src = ''; });

  // 국토대장정 활동 사진 모달
  const nwModal = document.getElementById('nationwide-walk-modal') as HTMLDialogElement | null;
  document.querySelectorAll<HTMLButtonElement>('[data-modal-open="nationwide-walk"]').forEach(btn => {
    btn.addEventListener('click', () => nwModal?.showModal());
  });
  nwModal?.querySelector('[data-nw-close]')?.addEventListener('click', () => nwModal.close());
  nwModal?.addEventListener('click', (e) => { if (e.target === nwModal) nwModal.close(); });

  // OVAL KOREA 지부 안내 모달
  const ovalBranches: Record<string, { name: string; channel: string; url: string }> = {
    japan: { name: 'OVAL 일본 지부', channel: '공식 웹사이트', url: 'https://www.oval-japan-official.org/' },
    korea: { name: 'OVAL 한국 지부', channel: '공식 Instagram', url: 'https://www.instagram.com/ovalkorea/' },
    china: { name: 'OVAL 중국 지부', channel: '공식 Instagram', url: 'https://www.instagram.com/ovalchina/' },
  };
  const ovalModal = document.getElementById('oval-modal') as HTMLDialogElement | null;
  const ovalNameEl   = ovalModal?.querySelector<HTMLElement>('[data-oval-name]')    ?? null;
  const ovalChEl     = ovalModal?.querySelector<HTMLElement>('[data-oval-channel]') ?? null;
  const ovalUrlEl    = ovalModal?.querySelector<HTMLElement>('[data-oval-url]')     ?? null;
  const ovalLinkEl   = ovalModal?.querySelector<HTMLAnchorElement>('[data-oval-link]') ?? null;

  document.querySelectorAll<HTMLButtonElement>('[data-modal-open="oval"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const branch = ovalBranches[btn.dataset.ovalBranch ?? ''];
      if (!branch || !ovalModal) return;
      if (ovalNameEl)  ovalNameEl.textContent  = branch.name;
      if (ovalChEl)    ovalChEl.textContent     = branch.channel;
      if (ovalUrlEl)   ovalUrlEl.textContent    = branch.url;
      if (ovalLinkEl)  ovalLinkEl.href          = branch.url;
      ovalModal.showModal();
    });
  });
  ovalModal?.querySelector('[data-oval-close]')?.addEventListener('click', () => ovalModal.close());
  ovalModal?.addEventListener('click', (e) => { if (e.target === ovalModal) ovalModal.close(); });

  // 휴먼-생태분석 연구실 안내 모달
  const healLabModal = document.getElementById('heal-lab-modal') as HTMLDialogElement | null;
  document.querySelectorAll<HTMLButtonElement>('[data-modal-open="heal-lab"]').forEach(btn => {
    btn.addEventListener('click', () => healLabModal?.showModal());
  });
  healLabModal?.querySelector('[data-heal-lab-close]')?.addEventListener('click', () => healLabModal.close());
  healLabModal?.addEventListener('click', (e) => { if (e.target === healLabModal) healLabModal.close(); });

  // 한양대학교 홈페이지 안내 모달
  const hanyangMajorModal = document.getElementById('hanyang-major-modal') as HTMLDialogElement | null;
  document.querySelectorAll<HTMLButtonElement>('[data-modal-open="hanyang-major"]').forEach(btn => {
    btn.addEventListener('click', () => hanyangMajorModal?.showModal());
  });
  hanyangMajorModal?.querySelector('[data-hanyang-major-close]')?.addEventListener('click', () => hanyangMajorModal.close());
  hanyangMajorModal?.addEventListener('click', (e) => { if (e.target === hanyangMajorModal) hanyangMajorModal.close(); });
</script>
