---
import BaseLayout from "../../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
const img = (name: string) => `${base}projects/${name}`;

const steps = [
  { label: "발견",  sub: "현장 조사 및\n이해관계자 인터뷰" },
  { label: "정의",  sub: "인사이트 도출 및\n문제 정의" },
  { label: "발산",  sub: "아이디어 브레인스토밍\n및 콘셉트 도출" },
  { label: "설계",  sub: "캠페인/경험 설계\n프로토타입 제작" },
  { label: "실행",  sub: "버스킹 운영 및\n시민 참여 유도" },
  { label: "평가",  sub: "피드백 수집 및\n임팩트 측정" },
];

const tasks = [
  { title: "현장 조사",        desc: "안산 지역 주민, 청년, 상인, 외국인 대상 인터뷰 및 관찰 조사 진행" },
  { title: "경험 디자인",      desc: "시민 여정을 기반으로 캠페인 흐름과 참여 방식 설계" },
  { title: "콘텐츠 기획",      desc: "음악, 인터랙티브 게임, 포토존 등 참여 콘텐츠 개발" },
  { title: "운영 및 실행",     desc: "현장 운영, 부스 관리, 리허설 및 위기 대응까지 직접 수행" },
  { title: "평가 및 리서치 도출", desc: "시민 피드백 분석으로 개선점 도출 및 후속 제안 정리" },
];

const citizenFlow = [
  { label: "관심 유도",  sub: "음악/퍼포먼스로\n시선 끌기" },
  { label: "참여 유도",  sub: "부스 및 미션 안내,\nQR 스캔 유도" },
  { label: "체험 및 공감", sub: "게임, 설문, 메시지\n작성 등 함께 체험" },
  { label: "공유 및 확산", sub: "시민 활동 및 SNS 공유,\n캠페인 메시지 확산" },
];

const tools = [
  { name: "Figma",        sub: "디자인 및 프로토타입", color: "bg-[#F24E1E]", letter: "F" },
  { name: "Miro",         sub: "아이디어 발산",         color: "bg-[#FFD02F]", letter: "M", dark: true },
  { name: "Notion",       sub: "문서화 및 일정 관리",   color: "bg-gray-900",  letter: "N" },
  { name: "Google Forms", sub: "설문 및 데이터 수집",   color: "bg-[#7B4BD1]", letter: "G" },
  { name: "Instagram",    sub: "홍보 및 소통",           color: "bg-[#E1306C]", letter: "in" },
  { name: "Canva",        sub: "홍보물 제작",            color: "bg-[#00C4CC]", letter: "C" },
];

const headerBgs = ["bg-green-50", "bg-amber-50", "bg-purple-50"];
---

<BaseLayout title="카카오 안산 임팩트 챌린지 2024" description="아이디어에서 실제 시민 경험으로, 우리가 만든 변화의 여정">

  <!-- 뒤로 가기 -->
  <div class="max-w-5xl mx-auto px-6 pt-6">
    <a href={`${base}projects`} class="inline-flex items-center gap-1 text-xs text-gray-400 hover:text-gray-700 transition-colors">
      ← Projects로 돌아가기
    </a>
  </div>

  <!-- ═══════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════ -->
  <section class="relative bg-gray-900 text-white overflow-hidden">
    <img src={img("kakao-ansan.png")} alt="" aria-hidden="true"
         class="absolute inset-0 w-full h-full object-cover opacity-40" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/50 to-black/20"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6">
      <!-- Main grid: 제목 | 요약 카드 -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-8 items-start pt-10 pb-10">

        <!-- Left: 제목 영역 -->
        <div>
          <span class="text-xs font-bold tracking-widest text-green-400 uppercase mb-4 block">
            커뮤니티 임팩트 프로젝트
          </span>
          <h1 class="text-5xl md:text-6xl font-bold leading-[1.1] mb-5">
            카카오 안산 임팩트<br />챌린지 2024
          </h1>
          <p class="text-white/75 text-base leading-relaxed">
            아이디어에서 실제 시민 경험으로,<br />우리가 만든 변화의 여정
          </p>

          <!-- 메타데이터 -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-1 gap-y-3 mt-5">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-white/50 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
              </svg>
              <div>
                <div class="text-white/50 text-xs">참여 인원</div>
                <div class="font-medium text-white text-xs">7명+ (팀 버스킹)</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-white/50 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              <div>
                <div class="text-white/50 text-xs">전체 기간</div>
                <div class="font-medium text-white text-xs">2024.07 – 2024.12</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-white/50 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
              </svg>
              <div>
                <div class="text-white/50 text-xs">주관</div>
                <div class="font-medium text-white text-xs">카카오, 한양대학교</div>
              </div>
            </div>
            <div class="flex items-center gap-2 min-w-0">
              <svg class="w-4 h-4 text-white/50 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
              <div class="min-w-0">
                <div class="text-white/50 text-xs">협력</div>
                <div class="font-medium text-white text-xs whitespace-nowrap">안산시 지속가능발전협의회</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: 프로젝트 한눈에 보기 카드 -->
        <div class="bg-white text-gray-900 rounded-xl p-5 shadow-2xl self-start mt-4 lg:mt-0">
          <h3 class="font-bold text-sm text-gray-900 mb-4 pb-3 border-b border-gray-100">프로젝트 한눈에 보기</h3>
          <dl class="space-y-3 text-xs">

            <div class="flex gap-3 items-start">
              <div class="w-7 h-7 rounded-lg bg-green-50 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-700" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                </svg>
              </div>
              <div>
                <dt class="text-gray-400 font-medium mb-0.5">역할</dt>
                <dd class="text-gray-800">팀 리더 · 프로젝트 매니저 · 서비스/경험 기획</dd>
              </div>
            </div>

            <div class="flex gap-3 items-start">
              <div class="w-7 h-7 rounded-lg bg-green-50 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-700" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              </div>
              <div>
                <dt class="text-gray-400 font-medium mb-0.5">파트너</dt>
                <dd class="text-gray-800">카카오임팩트재단, 안산시, 한양대학교</dd>
              </div>
            </div>

            <div class="flex gap-3 items-start">
              <div class="w-7 h-7 rounded-lg bg-green-50 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-700" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                </svg>
              </div>
              <div>
                <dt class="text-gray-400 font-medium mb-0.5">주요 활동</dt>
                <dd class="text-gray-800">현장조사, 디자인씽킹, 캠페인 기획, 운영, 시민 참여 설계</dd>
              </div>
            </div>

            <div class="flex gap-3 items-start">
              <div class="w-7 h-7 rounded-lg bg-green-50 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-700" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
              </div>
              <div>
                <dt class="text-gray-400 font-medium mb-0.5">성과</dt>
                <dd class="text-gray-800">시민 참여 200+명, 피드백 긍정 응답 85% 이상,<br />지역사회 공감대 형성 및 후속 활동 제안</dd>
              </div>
            </div>

            <div class="flex gap-3 items-start">
              <div class="w-7 h-7 rounded-lg bg-green-50 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-green-700" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
                </svg>
              </div>
              <div>
                <dt class="text-gray-400 font-medium mb-0.5">핵심 키워드</dt>
                <dd class="text-gray-800">지역문제 해결, 시민 참여, 경험 디자인, 협업, 실행</dd>
              </div>
            </div>

          </dl>
        </div>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       MAIN CONTENT
  ════════════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-6">

    <!-- 01 문제 정의 + 02 접근 방법 ─────────────────────── -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 py-12 border-b border-gray-100">

      <!-- 01 문제 정의 -->
      <section>
        <div class="flex items-center gap-2 mb-5">
          <span class="text-xs font-bold text-green-600 tracking-widest border-b-2 border-green-500 pb-0.5">01</span>
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">문제 정의</span>
        </div>
        <h2 class="text-xl font-bold text-gray-900 leading-snug mb-3">
          안산에는 다양한 문화와 사람들이 공존하지만,<br />
          서로 연결되고 소통할 수 있는 기회가 부족했습니다.
        </h2>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          외국인 인구 증가, 청년층의 지역 참여 부족, 세대 간 교류 단절 등으로<br />지역 공동체의 유대감이 약화되고 있었습니다.
        </p>
        <div class="grid grid-cols-3 gap-3">
          {[
            { icon: "M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z", title: "낮은 지역 참여도",  desc: "지역 행사 참여율이 낮고, 관심과 연결의 계기가 부족" },
            { icon: "M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155", title: "소통의 장 부재",   desc: "다양한 문화권과 세대가 자연스럽게 만날 수 있는 콘텐츠 부족" },
            { icon: "M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z", title: "공공공간 활용 미흡", desc: "시민들이 즐길 수 있는 열린 문화 경험이 부족" },
          ].map(({ icon, title, desc }) => (
            <div class="bg-gray-50 rounded-xl p-4 flex flex-col gap-2">
              <div class="w-9 h-9 rounded-lg bg-white flex items-center justify-center shadow-sm">
                <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                </svg>
              </div>
              <p class="text-xs font-semibold text-gray-800 leading-snug">{title}</p>
              <p class="text-xs text-gray-500 leading-snug">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- 02 접근 방법 -->
      <section>
        <div class="flex items-center gap-2 mb-5">
          <span class="text-xs font-bold text-green-600 tracking-widest border-b-2 border-green-500 pb-0.5">02</span>
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">접근 방법</span>
        </div>
        <h2 class="text-xl font-bold text-gray-900 leading-snug mb-3">
          음악과 참여를 통해 누구나 즐겁게 참여할 수 있는<br />
          공개 캠페인(버스킹)을 기획했습니다.
        </h2>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
