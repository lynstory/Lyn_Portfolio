            <div class="flex flex-col items-center text-center relative z-10">
              <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                </svg>
              </div>
              <p class="text-[11px] font-semibold text-gray-900 leading-tight">정의하기</p>
              <p class="text-[10px] text-gray-400 leading-snug mt-0.5">인사이트 도출<br />문제정의</p>
            </div>

            <div class="flex flex-col items-center text-center relative z-10">
              <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                </svg>
              </div>
              <p class="text-[11px] font-semibold text-gray-900 leading-tight">아이디어<br />내기</p>
              <p class="text-[10px] text-gray-400 leading-snug mt-0.5">브레인스토밍<br />발산</p>
            </div>

            <div class="flex flex-col items-center text-center relative z-10">
              <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                </svg>
              </div>
              <p class="text-[11px] font-semibold text-gray-900 leading-tight">만들어<br />보기</p>
              <p class="text-[10px] text-gray-400 leading-snug mt-0.5">프로토타입<br />모델링</p>
            </div>

            <div class="flex flex-col items-center text-center relative z-10">
              <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                </svg>
              </div>
              <p class="text-[11px] font-semibold text-gray-900 leading-tight">검증하기</p>
              <p class="text-[10px] text-gray-400 leading-snug mt-0.5">피드백 수집<br />개선</p>
            </div>

          </div>
        </div>
      </section>
    </div>

    <!-- ─── Row 2: 03 프로그램 흐름 ─── -->
    <section class="py-12 border-b border-gray-100">
      <p class="inline-flex items-center gap-1.5 text-[11px] font-bold tracking-widest uppercase mb-5">
        <span class="text-blue-600 border-b-2 border-blue-500 pb-0.5">03</span>
        <span class="text-gray-500 ml-1">프로그램 흐름</span>
      </p>

      <!-- 가이드 라인 + 도트 (데스크탑) -->
      <div class="relative mb-2 hidden lg:block">
        <div class="absolute top-1/2 -translate-y-1/2 left-[calc(100%/12)] right-[calc(100%/12)] h-px bg-gray-200"></div>
        <div class="grid grid-cols-6">
          {[1,2,3,4,5,6].map(() => (
            <div class="flex justify-center py-2 relative z-10">
              <div class="w-2.5 h-2.5 rounded-full bg-blue-500 ring-2 ring-white"></div>
            </div>
          ))}
        </div>
      </div>

      <!-- 6 카드 -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {days.map((day) => (
          <div class="border border-gray-100 rounded-xl bg-white overflow-hidden flex flex-col">
            <div class="p-4 flex-1">
              <p class="text-[10px] text-blue-500 font-semibold tracking-wider mb-1">Day {day.n}</p>
              <p class="text-sm font-bold text-gray-900 leading-snug mb-2">{day.line1}<br />{day.line2}</p>
              <p class="text-[11px] text-gray-500 leading-relaxed">{day.desc}</p>
            </div>
            <div class="h-28 shrink-0 overflow-hidden">
              <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover" />
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── Row 3: 04 + 05 (2:3) ─── -->
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-10 py-12 border-b border-gray-100 items-start">

      <!-- 04 내가 한 역할 -->
      <section>
        <p class="inline-flex items-center gap-1.5 text-[11px] font-bold tracking-widest uppercase mb-4">
          <span class="text-blue-600 border-b-2 border-blue-500 pb-0.5">04</span>
          <span class="text-gray-500 ml-1">내가 한 역할</span>
        </p>
        <h2 class="text-lg font-bold text-gray-900 leading-snug mb-4">
          퍼실리테이터로서 팀의 협업과<br />문제 해결 과정을 이끌었습니다.
        </h2>
        <div class="grid grid-cols-[1fr_140px] gap-4 items-start">
          <ul class="space-y-2.5">
            {bullets.map((item) => (
              <li class="flex items-start gap-2">
                <div class="w-5 h-5 rounded-full bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-blue-600">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </div>
                <span class="text-xs text-gray-600 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
          <div class="aspect-[3/4] overflow-hidden rounded-lg">
            <img src={`${base}projects/apye-korea.png`} alt="APYE Korea" class="w-full h-full object-cover" />
          </div>
        </div>
      </section>

      <!-- 05 현장 활동 사진 -->
      <section class="flex flex-col">
        <p class="inline-flex items-center gap-1.5 text-[11px] font-bold tracking-widest uppercase mb-4">
          <span class="text-blue-600 border-b-2 border-blue-500 pb-0.5">05</span>
          <span class="text-gray-500 ml-1">현장 활동 사진</span>
        </p>
        <!-- 9장 콜라주: 4 cols × 3 rows -->
        <!-- A(2×2) + B,C,D,E(우 2×2) + F,G,H,I(하단 4장) = 총 9장 -->
        <div
          class="flex-1 grid grid-cols-4 gap-1.5"
          style="grid-template-rows: 1fr 1fr 0.65fr; min-height: 360px;"
        >
          <!-- A: col 1-2, row 1-2 (대형 단체사진) -->
          <div class="col-span-2 row-span-2 overflow-hidden rounded-lg">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-center" />
          </div>
          <!-- B: col 3, row 1 -->
          <div class="overflow-hidden rounded-md">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-top" />
          </div>
          <!-- C: col 4, row 1 -->
          <div class="overflow-hidden rounded-md">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-right" />
          </div>
          <!-- D: col 3, row 2 -->
          <div class="overflow-hidden rounded-md">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-bottom" />
          </div>
          <!-- E: col 4, row 2 -->
          <div class="overflow-hidden rounded-md">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-left" />
          </div>
          <!-- F: col 1, row 3 -->
          <div class="overflow-hidden rounded-md">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-right-bottom" />
          </div>
          <!-- G: col 2, row 3 -->
          <div class="overflow-hidden rounded-md">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-center" />
          </div>
          <!-- H: col 3, row 3 -->
          <div class="overflow-hidden rounded-md">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-left-bottom" />
          </div>
          <!-- I: col 4, row 3 -->
          <div class="overflow-hidden rounded-md">
            <img src={`${base}projects/kakao-ansan.png`} alt="" class="w-full h-full object-cover object-left-top" />
          </div>
        </div>
      </section>
    </div>

    <!-- ─── Row 4: 07 + 08 (2:3) ─── -->
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-10 py-12">

      <!-- 07 배운 점 -->
      <section>
        <p class="inline-flex items-center gap-1.5 text-[11px] font-bold tracking-widest uppercase mb-4">
          <span class="text-blue-600 border-b-2 border-blue-500 pb-0.5">07</span>
          <span class="text-gray-500 ml-1">배운 점</span>
        </p>
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-white border border-gray-100 rounded-xl p-4 text-center">
            <div class="flex justify-center mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-blue-500">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
