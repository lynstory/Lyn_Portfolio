---
import BaseLayout from "../../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;

const days = [
  { n: 1, line1: "Team Building", line2: "& SDGs 교육", desc: "팀 빌딩, 프로그램 소개, SDGs 및 사회혁신 이해" },
  { n: 2, line1: "Design Thinking", line2: "워크숍", desc: "디자인씽킹 방법론 학습, 문제 정의 및 공감하기" },
  { n: 3, line1: "Local Immersion", line2: "(현장 조사)", desc: "성동구 지역 탐방, 이해관계자 인터뷰, 문제 발견" },
  { n: 4, line1: "Ideation &", line2: "Prototyping", desc: "아이디어 브레인스토밍, 솔루션 구체화 및 프로토타입 제작" },
  { n: 5, line1: "Symposium", line2: "(최종 발표)", desc: "팀별 솔루션 발표 및 전문가 피드백" },
  { n: 6, line1: "왕십리 광장", line2: "시민 캠페인", desc: "솔루션을 시민들과 공유하고 인식 개선 캠페인 진행" },
];

const bullets = [
  "글로벌 팀(국적 혼합) 퍼실리테이션 및 커뮤니케이션 지원",
  "디자인씽킹 워크숍 진행 및 아이디어 발산 촉진",
  "현장조사(인터뷰, 관찰) 일정 기획 및 운영",
  "팀의 인사이트 정리 및 문제 정의 지원",
  "프로토타입 제작 가이드 및 발표 코칭",
  "다문화 환경에서의 갈등 조정 및 동기 부여",
];

const tools = [
  "포스트잇, 화이트보드",
  "Miro (온라인 협업 보드)",
  "구글 설문지",
  "카메라, 녹음기 (인터뷰 기록)",
  "PPT / Keynote",
];

const methods = [
  "디자인씽킹", "리서치 (인터뷰, 관찰)", "브레인라이팅",
  "SCAMPER", "페르소나", "스토리보드", "프로토타이핑", "피드백 루프",
];

const photoPos = [
  "object-center", "object-top", "object-right",
  "object-bottom", "object-left", "object-right-bottom",
  "object-center", "object-left-bottom", "object-left-top",
];
---

<BaseLayout
  title="APYE Korea 2018 | Lyn Portfolio"
  description="퍼실리테이터로서 팀의 협업과 문제 해결 과정을 이끌었습니다."
>

  <!-- 뒤로가기 -->
  <div class="max-w-6xl mx-auto px-6 pt-6 pb-2">
    <a href={`${base}projects`} class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      Projects
    </a>
  </div>

  <!-- ═══ HERO ═══ -->
  <section class="relative bg-gray-900 text-white overflow-hidden">
    <img src={`${base}projects/apye-korea.png`} alt="" class="absolute inset-0 w-full h-full object-cover opacity-40 select-none pointer-events-none" />
    <div class="absolute inset-0 bg-gradient-to-br from-black/85 via-black/60 to-black/30"></div>

    <div class="relative max-w-6xl mx-auto px-6 py-14 grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8 items-start">

      <!-- Left -->
      <div>
        <p class="text-[11px] tracking-widest text-blue-300 uppercase mb-4">Impact · 사회혁신 · 청년 리더십</p>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-2">APYE Korea 2018</h1>
        <p class="text-blue-200 text-base mb-3">Asia Pacific Youth Exchange</p>
        <p class="text-white/70 text-sm leading-relaxed max-w-xl">
          청년들이 모여 SDGs를 기반으로 지역 문제를 탐색하고, 디자인씽킹으로 솔루션을 만들어 시민에게 직접 제안한 국제 사회혁신 프로그램입니다.
        </p>

        <!-- 메타 row -->
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-blue-300">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] text-white/50 mb-0.5">기간</p>
              <p class="text-xs font-medium">2018.08 /<br />2019.03–08</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-blue-300">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] text-white/50 mb-0.5">역할</p>
              <p class="text-xs font-medium">퍼실리테이터</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-blue-300">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] text-white/50 mb-0.5">참여 규모</p>
              <p class="text-xs font-medium">20여 개국 180명+<br />국내외 청년 Faci 30+명</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-blue-300">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] text-white/50 mb-0.5">장소</p>
              <p class="text-xs font-medium">서울 성동구 일대<br />서울·대구·안산</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: 프로젝트 한눈에 보기 -->
      <div class="bg-white text-gray-900 rounded-2xl p-5 shadow-xl">
        <p class="font-bold text-sm border-b border-gray-100 pb-3 mb-4">프로젝트 한눈에 보기</p>
        <div class="space-y-4">

          <div class="flex items-start gap-3">
            <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-blue-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] tracking-wider text-gray-400 uppercase mb-0.5">주체 / 주관</p>
              <p class="text-xs text-gray-700 leading-relaxed">한양대학교, Urban Youth Academy,<br />Asian Development Bank, UNDP</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-blue-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] tracking-wider text-gray-400 uppercase mb-0.5">협력기관</p>
              <p class="text-xs text-gray-700 leading-relaxed">성동구청, 성동청년지원센터, SK행복나눔재단,<br />영국문화원, 서울새활용플라자, 지역기관 및 NGO 등</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-blue-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] tracking-wider text-gray-400 uppercase mb-0.5">핵심목표</p>
              <p class="text-xs text-gray-700 leading-relaxed">SDGs 기반의 지역문제 해결 아이디어 도출 및<br />소셜벤처 모델 제안</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-blue-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] tracking-wider text-gray-400 uppercase mb-0.5">주요활동</p>
              <p class="text-xs text-gray-700 leading-relaxed">디자인씽킹 워크숍, 현장조사, 이해관계자 인터뷰,<br />아이디어 개발, 프로토타입, 솔루션제안, 시민 캠페인</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-blue-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] tracking-wider text-gray-400 uppercase mb-0.5">최종결과</p>
              <p class="text-xs text-gray-700 leading-relaxed">지역 문제 해결을 위한 솔루션 제안, 시민 캠페인 실행</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Main Content ═══ -->
  <div class="max-w-6xl mx-auto px-6">

    <!-- ─── Row 1: 01 + 02 ─── -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 py-12 border-b border-gray-100">

      <!-- 01 문제 정의 -->
      <section>
        <p class="inline-flex items-center gap-1.5 text-[11px] font-bold tracking-widest uppercase mb-4">
          <span class="text-blue-600 border-b-2 border-blue-500 pb-0.5">01</span>
          <span class="text-gray-500 ml-1">문제 정의</span>
        </p>
        <h2 class="text-xl font-bold text-gray-900 leading-snug mb-3">
          지역 곳곳의 문제들이 존재하지만,<br />지속가능한 해결 방안은 부족했습니다.
        </h2>
        <p class="text-sm text-gray-500 leading-relaxed mb-5">
          성동구 일대에는 다양한 지역 문제가 산재해 있었지만,<br />이해관계자와 함께 지속적으로 해결하려는 구조적 시도는 드물었습니다.
        </p>
        <div class="grid grid-cols-3 gap-2">
          <div class="border border-gray-200 rounded-lg p-3 bg-white">
            <div class="w-7 h-7 rounded-md bg-blue-50 flex items-center justify-center mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-blue-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
            </div>
            <p class="text-[11px] font-semibold text-gray-800 leading-snug">이해관계자 없는 문제 정의</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-3 bg-white">
            <div class="w-7 h-7 rounded-md bg-blue-50 flex items-center justify-center mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-blue-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3-3 3" />
              </svg>
            </div>
            <p class="text-[11px] font-semibold text-gray-800 leading-snug">지속가능한 해결 문화 부재</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-3 bg-white">
            <div class="w-7 h-7 rounded-md bg-blue-50 flex items-center justify-center mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-blue-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
              </svg>
            </div>
            <p class="text-[11px] font-semibold text-gray-800 leading-snug">현지인 참여 봉사 부족</p>
          </div>
        </div>
      </section>

      <!-- 02 접근 방법 -->
      <section>
        <p class="inline-flex items-center gap-1.5 text-[11px] font-bold tracking-widest uppercase mb-4">
          <span class="text-blue-600 border-b-2 border-blue-500 pb-0.5">02</span>
          <span class="text-gray-500 ml-1">접근 방법</span>
        </p>
        <h2 class="text-xl font-bold text-gray-900 leading-snug mb-3">
          디자인씽킹과 현장 몰입을 통해<br />사람 중심의 솔루션을 고민했습니다.
        </h2>
        <p class="text-sm text-gray-500 leading-relaxed mb-5">
          이해하기부터 검증하기까지 5단계 디자인씽킹 프로세스를 팀과 함께 실행했습니다.
        </p>

        <!-- 5단계 프로세스 -->
        <div class="relative">
          <div class="absolute top-6 left-[10%] right-[10%] border-t-2 border-dashed border-gray-200 hidden sm:block"></div>
          <div class="grid grid-cols-5 gap-1">

            <div class="flex flex-col items-center text-center relative z-10">
              <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 mb-2">
