---
// ROADMAP §2.1: Side Quests는 메인 네비에서 미노출. About 본문 내부 링크로만 진입.
// Phase 2: Content Collections 기반으로 자동화 (src/content/side-quests/*.mdx)
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SideQuestCard from "../components/SideQuestCard.astro";

const allSideQuests = await getCollection("sideQuests");

// order asc 정렬 (1이 최상단)
const sorted = allSideQuests.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Side Quests" description="메인 커리어 동선 밖의 개인 도전과 사업 이야기.">
  <div class="max-w-3xl mx-auto px-6 py-20">

    <!-- 돌아가기 링크 (About에서만 진입하는 동선 명시) -->
    <a href="/about" class="inline-flex items-center gap-1 text-xs text-gray-400 hover:text-accent transition-colors mb-12">
      ← About으로 돌아가기
    </a>

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">Side Quests</h1>

    <!-- TODO: 짧은 소개 작성 (개인적·솔직한 톤 — ROADMAP §3) -->
    <!-- PM 채용 동선과 격리되어 있어 자유롭게 표현 가능 (ROADMAP §2.2 Side Quests) -->
    <p class="text-gray-500 mb-14 leading-relaxed">
      <!-- TODO -->
    </p>

    <!-- 등재 항목 카드 (ROADMAP §2.2 Side Quests) -->
    <div class="fade-in-up grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {sorted.map((entry) => <SideQuestCard entry={entry} />)}
    </div>

  </div>
</BaseLayout>
