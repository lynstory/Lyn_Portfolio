---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact" description="협업 제안, 채용 문의, 네트워킹 등 편하게 연락 주세요.">
  <div class="min-h-full bg-(--color-bg-warm)">
    <div class="max-w-xl mx-auto px-6 py-20">

      <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-5">CONTACT</p>

      <h1 class="text-6xl font-bold text-gray-900 mb-8">Contact</h1>

      <p class="text-xl font-bold text-gray-900 leading-tight mb-3">
        협업 제안, 채용 문의, 네트워킹 등<br />편하게 연락 주세요.
      </p>

      <p class="text-sm text-gray-400 mb-12">다양한 기회와 의미 있는 대화를 환영합니다.</p>

      <div class="fade-in-up space-y-4">

        <!-- EMAIL 카드 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 flex items-center gap-5">
          <div class="w-12 h-12 rounded-xl bg-gray-50 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-700">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <span class="text-xs font-semibold tracking-widest uppercase text-gray-400 w-24 shrink-0">EMAIL</span>
          <a
            href="mailto:lyn357abc@gmail.com"
            class="text-gray-900 hover:text-accent transition-colors text-sm"
          >
            lyn357abc@gmail.com
          </a>
        </div>

        <!-- GITHUB 카드 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 flex items-center gap-5">
          <div class="w-12 h-12 rounded-xl bg-gray-50 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-gray-700">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z" clip-rule="evenodd" />
            </svg>
          </div>
          <span class="text-xs font-semibold tracking-widest uppercase text-gray-400 w-24 shrink-0">GITHUB</span>
          <a
            href="https://github.com/lynstory"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-900 hover:text-accent transition-colors text-sm"
          >
            @lynstory
          </a>
        </div>

        <!-- RESUME 카드 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 flex items-center gap-5">
          <div class="w-12 h-12 rounded-xl bg-gray-50 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-700">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
          </div>
          <span class="text-xs font-semibold tracking-widest uppercase text-gray-400 w-24 shrink-0">RESUME</span>
          <a
            href={`${base}resume.pdf`}
            download
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-white text-sm font-medium rounded-lg hover:opacity-90 transition-opacity"
          >
            PDF 다운로드
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>
