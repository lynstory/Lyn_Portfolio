---
// ROADMAP §2.2 Contact
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="협업 제안, 채용 문의, 네트워킹 등 편하게 연락 주세요.">
  <div class="max-w-2xl mx-auto px-6 py-20">

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">Contact</h1>
    <p class="text-gray-500 mb-14 text-sm leading-relaxed">
      협업 제안, 채용 문의, 네트워킹 등 편하게 연락 주세요.
    </p>

    <ul class="fade-in-up space-y-8 list-none m-0 p-0">

      <!-- 이메일 (ROADMAP §2.2 Contact) -->
      <li class="flex items-center gap-6">
        <span class="w-20 text-xs font-semibold text-gray-400 uppercase tracking-wider shrink-0">Email</span>
        <a
          href="mailto:lyn357abc@gmail.com"
          class="text-gray-800 hover:text-accent transition-colors text-sm"
        >
          lyn357abc@gmail.com
        </a>
      </li>

      <!-- GitHub (ROADMAP §2.2 Contact) -->
      <li class="flex items-center gap-6">
        <span class="w-20 text-xs font-semibold text-gray-400 uppercase tracking-wider shrink-0">GitHub</span>
        <a
          href="https://github.com/lynstory"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-800 hover:text-accent transition-colors text-sm"
        >
          @lynstory
        </a>
      </li>

      <!-- LinkedIn: TODO (ROADMAP §2.2 Contact — "있다면") -->
      <!-- TODO: LinkedIn URL 확인 후 주석 해제하여 추가 -->
      <!--
      <li class="flex items-center gap-6">
        <span class="w-20 text-xs font-semibold text-gray-400 uppercase tracking-wider shrink-0">LinkedIn</span>
        <a href="https://linkedin.com/in/..." target="_blank" rel="noopener noreferrer" class="text-gray-800 hover:text-accent transition-colors text-sm">
          LinkedIn 프로필
        </a>
      </li>
      -->

      <!-- Resume PDF 다운로드 (ROADMAP §2.2 Contact) -->
      <li class="flex items-center gap-6">
        <span class="w-20 text-xs font-semibold text-gray-400 uppercase tracking-wider shrink-0">Resume</span>
        <a
          href="/resume.pdf"
          download
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-white text-sm font-medium rounded-lg hover:opacity-90 transition-opacity"
        >
          PDF 다운로드
        </a>
      </li>

    </ul>

  </div>
</BaseLayout>
