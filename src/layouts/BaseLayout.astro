---
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  hideFooter?: boolean;
  ogTitle?: string;        // 소셜 카드 전용 제목 오버라이드
  ogDescription?: string;  // 소셜 카드 전용 설명 오버라이드
}

const { title, description = "PM 직무 어필 포트폴리오 — 문제를 정의하고 해결하는 기획자.", hideFooter = false, ogTitle, ogDescription } = Astro.props;

// 소셜 카드(og/twitter) 제목·설명 — 오버라이드 없으면 기본값 사용
const socialTitle = ogTitle ?? (title ? `${title} — Lyn` : "Lyn Portfolio");
const socialDescription = ogDescription ?? description;

// OG 미리보기 이미지 (절대 URL 필수) — public/Logo2.png 사용 (1254x1254)
const ogImage = new URL(`${import.meta.env.BASE_URL}Logo2.png`, Astro.site).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <!-- Google Analytics 4 (gtag.js) — 방문자 통계 수집 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2BMNCKF8YQ"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2BMNCKF8YQ');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- 폰트: Inter (영문) — Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- 폰트: Pretendard (국문) — jsDelivr CDN -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
    />

    <!-- 폰트: Playfair Display (영문 세리프 문구) — Google Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,500;1,600&display=swap"
      rel="stylesheet"
    />

    <!-- OG / Twitter 메타 -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Lyn Portfolio" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1254" />
    <meta property="og:image:height" content="1254" />
    <meta property="og:image:alt" content="Lyn Portfolio 로고" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title} | Lyn</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    {!hideFooter && <Footer />}
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll(".fade-in-up").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
