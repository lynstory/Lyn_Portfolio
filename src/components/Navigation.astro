---
// Side Quests는 의도적으로 메인 네비에서 미노출 (ROADMAP §2.1)
const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${base}about`, label: "About" },
  { href: `${base}projects`, label: "Projects" },
  { href: `${base}experience`, label: "Experience" },
  { href: `${base}contact`, label: "Contact" },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  return currentPath.startsWith(href);
}
---

<nav class="sticky top-0 z-50 bg-(--color-bg-warm) border-b border-[#E8E0D5]">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-8">
    <!-- 로고 -->
    <a href={base} class="flex items-center gap-2 font-bold text-base text-gray-900 tracking-widest hover:text-gray-600 transition-colors shrink-0">
      <img
        src={`${base}Logo2.png`}
        alt="Lyn 로고"
        class="w-8 h-8 rounded-full object-cover ring-1 ring-gray-300 shrink-0"
      />
      LYN.
    </a>

    <!-- 데스크탑 네비 -->
    <ul class="hidden md:flex gap-7 list-none m-0 p-0 flex-1 justify-center">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`text-sm font-medium transition-colors ${
              isActive(href)
                ? "text-gray-900 border-b-2 border-gray-900 pb-1"
                : "text-gray-500 hover:text-gray-900"
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Resume 버튼 + 햄버거 -->
    <div class="flex items-center gap-3 shrink-0">
      <a
        href={`${base}resume.pdf`}
        download
        class="hidden md:inline-flex items-center px-4 py-1.5 bg-gray-900 text-white text-sm font-medium rounded hover:bg-gray-700 transition-colors"
      >
        Resume
      </a>

      <!-- 모바일 햄버거 버튼 -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-gray-500 hover:text-gray-900 transition-colors"
        aria-label="메뉴 열기/닫기"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- 모바일 드롭다운 -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[#E8E0D5] bg-(--color-bg-warm)">
    <ul class="px-6 py-4 flex flex-col gap-1 list-none m-0">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`block py-2 text-sm font-medium transition-colors ${
              isActive(href) ? "text-gray-900" : "text-gray-500 hover:text-gray-900"
            }`}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-3 border-t border-gray-100 mt-2">
        <a
          href={`${base}resume.pdf`}
          download
          class="block py-2 text-sm font-medium text-gray-900"
        >
          Resume 다운로드
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const close = () => {
    menu?.classList.add("hidden");
    btn?.setAttribute("aria-expanded", "false");
  };
  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    if (isOpen) {
      close();
    } else {
      menu?.classList.remove("hidden");
      btn?.setAttribute("aria-expanded", "true");
    }
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });
  menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
</script>
