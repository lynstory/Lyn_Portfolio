---
---
<div class="not-prose my-10 rounded-2xl border border-gray-100 bg-gray-50 p-6 md:p-10 font-sans">

  <!-- 그라디언트 라인 -->
  <div class="h-0.5 w-full rounded-full bg-gradient-to-r from-rose-400 via-violet-400 to-[#3B5BA9] opacity-60 mb-6"></div>

  <!-- 좌상단 캡션 -->
  <p class="text-xs font-semibold text-rose-600 tracking-widest uppercase mb-6">AI 기반 기획자 / PM / PO</p>

  <!-- 메인 헤딩 -->
  <h3 class="text-xl md:text-2xl font-bold text-gray-900 text-center mb-10">AI 시대 PM의 시간이 재분배된다</h3>

  <!-- 비교 다이어그램 (좌·중앙·우) -->
  <div class="flex flex-col md:flex-row items-center md:items-stretch gap-6 md:gap-4 mb-10">

    <!-- 좌: 기존 PM -->
    <div class="flex flex-col w-full md:flex-1">
      <p class="text-sm font-semibold text-gray-700 text-center mb-1">기존 PM</p>
      <p class="text-xs text-gray-400 text-center mb-3">How에 시간 소진</p>
      <div class="flex flex-col rounded-xl overflow-hidden border border-gray-200" style="height: 300px">
        <!-- Why 10% -->
        <div class="flex items-center justify-center border-b border-gray-200 bg-rose-50" style="flex: 10">
          <span class="text-sm font-bold text-rose-700">Why 10%</span>
        </div>
        <!-- What 20% -->
        <div class="flex items-center justify-center border-b border-gray-200 bg-amber-50" style="flex: 20">
          <span class="text-sm font-bold text-amber-700">What 20%</span>
        </div>
        <!-- How 70% -->
        <div class="flex flex-col items-center justify-center gap-1.5 bg-[#3B5BA9]/5 p-3" style="flex: 70">
          <span class="text-base font-bold text-[#3B5BA9]">How 70%</span>
          <p class="text-xs text-gray-500 text-center leading-relaxed">
            PRD 작성 · 리뷰 대기<br/>
            수정 · 재작성 · 회의<br/>
            문서 · 화면 정의서
          </p>
        </div>
      </div>
    </div>

    <!-- 중앙: Claude Code 흐름 (좌 박스 → 우 박스) -->
    <div class="flex md:flex-col items-center justify-center shrink-0">
      <!-- 데스크탑: 가로 화살표 (→) -->
      <div class="hidden md:flex flex-col items-center shrink-0">
        <!-- 좌·우 컬럼의 헤더 높이만큼 invisible placeholder -->
        <div class="invisible" aria-hidden="true">
          <p class="text-sm mb-1">.</p>
          <p class="text-xs mb-3">.</p>
        </div>
        <!-- 박스 높이(300px) 내 세로 중앙 정렬 -->
        <div class="flex flex-col items-center justify-center gap-1.5 px-2" style="height: 300px">
          <span class="text-xs font-semibold text-[#3B5BA9] whitespace-nowrap">Claude Code</span>
          <div class="flex items-center">
            <div class="h-px w-10 border-t-2 border-dashed border-[#3B5BA9]/50"></div>
            <svg width="7" height="10" viewBox="0 0 7 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 5L0.25 9.33013L0.25 0.669872L7 5Z" fill="#3B5BA9" opacity="0.7"/>
            </svg>
          </div>
          <span class="text-xs text-gray-400 whitespace-nowrap">How 자동화</span>
        </div>
      </div>
      <!-- 모바일: 세로 화살표 (↓) -->
      <div class="md:hidden flex flex-col items-center gap-1.5 py-2">
        <span class="text-xs font-semibold text-[#3B5BA9] whitespace-nowrap">Claude Code</span>
        <div class="flex flex-col items-center">
          <div class="w-px h-8 border-l-2 border-dashed border-[#3B5BA9]/50"></div>
          <svg width="10" height="7" viewBox="0 0 10 7" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 7L0.669873 0.25L9.33013 0.249999L5 7Z" fill="#3B5BA9" opacity="0.7"/>
          </svg>
        </div>
        <span class="text-xs text-gray-400 whitespace-nowrap">How 자동화</span>
      </div>
    </div>

    <!-- 우: AI 시대 PM -->
    <div class="flex flex-col w-full md:flex-1">
      <p class="text-sm font-semibold text-gray-700 text-center mb-1">AI 시대 PM</p>
      <p class="text-xs text-gray-400 text-center mb-3">Why/What에 집중</p>
      <div class="flex flex-col rounded-xl overflow-hidden border border-gray-200" style="height: 300px">
        <!-- Why 40% -->
        <div class="flex flex-col items-center justify-center border-b border-gray-200 bg-rose-50 p-3" style="flex: 40">
          <span class="text-base font-bold text-rose-700">Why 40%</span>
          <p class="text-xs text-gray-500 text-center leading-relaxed mt-1">
            고객 가치 · 비즈니스 목표<br/>
            시장 · 우선순위 판단
          </p>
        </div>
        <!-- What 40% -->
        <div class="flex flex-col items-center justify-center border-b border-gray-200 bg-amber-50 p-3" style="flex: 40">
          <span class="text-base font-bold text-amber-700">What 40%</span>
          <p class="text-xs text-gray-500 text-center leading-relaxed mt-1">
            기능 정의 · 범위 결정<br/>
            MoSCoW · 수락 기준
          </p>
        </div>
        <!-- How 20% -->
        <div class="flex items-center justify-center bg-[#3B5BA9]/5" style="flex: 20">
          <span class="text-sm font-bold text-[#3B5BA9]">How 20% · AI 위임</span>
        </div>
      </div>
    </div>

  </div>

  <!-- 하단 메시지 -->
  <div class="text-center space-y-3 border-t border-gray-200 pt-8">
    <p class="text-sm text-gray-500">
      진짜 일은 <span class="font-bold text-rose-700">Why</span>와 <span class="font-bold text-amber-700">What</span> —
      <span class="font-semibold text-gray-900">빠르고 정확하게 결정</span>하라
    </p>
    <p class="text-lg md:text-xl font-bold text-gray-900 leading-snug">
      AI가 <span class="text-[#3B5BA9]">How</span>를 자동화할수록,<br/>
      PM은 <span class="text-rose-700">Why</span>/<span class="text-amber-700">What</span> 결정에 집중해야 한다
    </p>
  </div>

</div>
