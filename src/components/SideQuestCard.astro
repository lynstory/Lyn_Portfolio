---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"sideQuests">;
}

const { entry } = Astro.props;
const { title, period, tag, summary, current } = entry.data;
---

<a
  href={`/side-quests/${entry.id}`}
  class="block p-6 border border-gray-200 rounded-xl hover:border-accent/40 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_-2px_rgb(0_0_0_/_0.08)] transition-[transform,box-shadow,border-color] duration-200 group"
>
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <span class="px-2 py-1 bg-gray-100 text-xs font-medium text-gray-600 rounded">
      {tag}
    </span>
    {current && (
      <span class="px-2 py-1 bg-blue-50 text-accent text-xs font-medium rounded">진행 중</span>
    )}
  </div>
  <h2 class="text-xl font-bold text-gray-900 group-hover:text-accent transition-colors mb-1">
    {title}
  </h2>
  <p class="text-xs text-gray-400 mb-3">{period}</p>
  <p class="text-sm text-gray-500 leading-relaxed">{summary}</p>
</a>
