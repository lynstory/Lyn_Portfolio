---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-100 py-8 mt-16">
  <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-3 text-sm text-gray-400">
    <span>© {year} Lyn. All rights reserved.</span>
    <a
      href="https://github.com/lynstory"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-accent transition-colors"
    >
      GitHub @lynstory
    </a>
  </div>
</footer>
