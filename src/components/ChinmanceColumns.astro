---

<!-- 칼럼 카드 버튼 2x2 (왼위=1, 오른위=2, 왼아래=3, 오른아래=4) -->
<div class="not-prose grid grid-cols-2 gap-3 sm:gap-4 my-8">
  {columns.map((c) => (
    <button
      type="button"
      data-modal-open={c.key}
      class="group flex items-center justify-between gap-3 p-5 sm:p-6 bg-white border border-gray-200 rounded-2xl hover:border-gray-900 hover:shadow-md transition-all cursor-pointer text-left"
    >
      <span class="text-sm sm:text-base font-bold text-gray-900">{c.buttonLabel}</span>
      <span aria-hidden="true" class="text-gray-400 group-hover:text-gray-900 transition-colors">▸</span>
    </button>
  ))}
</div>

<!-- 칼럼 전문 모달 4개 -->
{columns.map((c) => (
  <dialog
    id={`${c.key}-modal`}
    class="not-prose fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-0 bg-transparent backdrop:bg-black/60 w-[92vw] max-w-lg"
    aria-label={c.title}
  >
    <div class="relative bg-white rounded-2xl max-h-[85vh] flex flex-col">
      <button
        type="button"
        data-modal-close
        aria-label="닫기"
        class="absolute top-3 right-3 z-10 w-8 h-8 flex items-center justify-center rounded-full bg-white/90 hover:bg-gray-100 text-gray-700 cursor-pointer shadow"
      >✕</button>
      <div class="overflow-y-auto p-6 sm:p-8">
        <h3 class="text-lg font-bold text-gray-900 mb-4 pr-8">{c.title}</h3>
        <p class="text-sm sm:text-base text-gray-700 leading-relaxed whitespace-pre-line">{c.body}</p>
      </div>
    </div>
  </dialog>
))}

<script>
  function wireModal(key: string) {
    const modal = document.getElementById(`${key}-modal`) as HTMLDialogElement | null;
    document.querySelectorAll<HTMLButtonElement>(`[data-modal-open="${key}"]`).forEach(btn => {
      btn.addEventListener('click', () => modal?.showModal());
    });
    modal?.querySelector('[data-modal-close]')?.addEventListener('click', () => modal?.close());
    modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
  }
  ['column-1', 'column-2', 'column-3', 'column-4'].forEach(wireModal);
</script>
