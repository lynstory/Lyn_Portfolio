---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const { title, summary, period, role, category, image } = entry.data;

const categoryGradients: Record<string, string> = {
  "기획":     "from-violet-50 to-purple-100",
  "공공·정책": "from-blue-50 to-slate-100",
  "임팩트":   "from-emerald-50 to-teal-100",
  "AI":       "from-amber-50 to-orange-100",
  "브랜딩":   "from-pink-50 to-rose-100",
};
const gradient = categoryGradients[category] ?? "from-gray-50 to-gray-100";
---

<a
  href={`${import.meta.env.BASE_URL}projects/${entry.id}`}
  class="block rounded-xl overflow-hidden border border-gray-200 hover:border-gray-300 hover:-translate-y-1 hover:shadow-[0_8px_24px_-4px_rgb(0_0_0_/_0.10)] transition-[transform,box-shadow,border-color] duration-200 group bg-white"
>
  <!-- 썸네일 이미지 -->
  <div class={`aspect-[4/3] overflow-hidden bg-gradient-to-br ${gradient} relative`}>
    {image ? (
      <img
        src={`${import.meta.env.BASE_URL}projects/${image}`}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-full"></div>
    )}
    <!-- 카테고리 배지 (이미지 위) -->
    <span class="absolute top-3 left-3 inline-block px-2 py-0.5 bg-white/80 backdrop-blur-sm text-xs font-medium text-gray-700 rounded">
      {category}
    </span>
  </div>

  <!-- 카드 내용 -->
  <div class="p-5">
    <h3 class="font-semibold text-gray-900 group-hover:text-gray-600 transition-colors leading-snug mb-1.5">
      {title}
    </h3>
    <p class="text-sm text-gray-500 leading-relaxed mb-3 line-clamp-2">{summary}</p>
    <!-- 메타 행: period / role / category -->
    <div class="flex flex-wrap items-center gap-1 text-xs text-gray-400">
      {period && <span>{period}</span>}
      {period && role && <span>/</span>}
      {role && <span>{role}</span>}
      {role && <span>/</span>}
      <span>{category}</span>
    </div>
  </div>
</a>
