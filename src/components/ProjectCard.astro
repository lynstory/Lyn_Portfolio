---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const { title, summary, period, role, category } = entry.data;
---

<a
  href={`${import.meta.env.BASE_URL}projects/${entry.id}`}
  class="block p-6 border border-gray-200 rounded-xl hover:border-accent/40 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_-2px_rgb(0_0_0_/_0.08)] transition-[transform,box-shadow,border-color] duration-200 group"
>
  <span class="inline-block px-2 py-1 bg-blue-50 text-accent text-xs font-medium rounded mb-4">
    {category}
  </span>
  <h3 class="font-semibold text-gray-900 group-hover:text-accent transition-colors leading-snug mb-2">
    {title}
  </h3>
  <p class="text-sm text-gray-500 leading-relaxed mb-4">{summary}</p>
  <div class="flex flex-wrap gap-3 text-xs text-gray-400">
    {period && <span>{period}</span>}
    {role && <span>{role}</span>}
  </div>
</a>
