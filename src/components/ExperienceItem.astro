---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

interface Props {
  entry: CollectionEntry<"experience">;
}

const { entry } = Astro.props;
const { title, period, org, category, current } = entry.data;
const { Content } = await render(entry);
const isBlenderUE = entry.id === "blender-unreal-edu";
const isAPYE = entry.id === "apye";
const isNationwideWalk = entry.id === "nationwide-walk";
const isOVAL = entry.id === "oval-korea";
const isHealLab = entry.id === "heal-lab";
const isHanyangMajor = entry.id === "hanyang-major";

const tagStyle: Record<string, string> = {
  "학교/학술":      "bg-blue-50 text-blue-700",
  "동아리/대외활동": "bg-emerald-50 text-emerald-700",
  "국제 활동":      "bg-sky-50 text-sky-700",
  "인턴/실무":      "bg-amber-50 text-amber-700",
  "교육과정":       "bg-violet-50 text-violet-700",
};
---

<li class="fade-in-up flex items-start" data-category={category}>

  <!-- 날짜 열: 데스크탑만 표시 -->
  <div class="hidden sm:block w-32 shrink-0 text-right pr-4 pt-5 text-sm text-gray-400 leading-snug">
    {period ?? ""}
  </div>

  <!-- 점 열 -->
  <div class="w-4 shrink-0 flex justify-center pt-5">
    <div class={`w-2.5 h-2.5 rounded-full z-10 relative ${current ? "bg-accent" : "bg-gray-800"}`}></div>
  </div>

  <!-- 카드 열 -->
  <div class="flex-1 pl-4 pb-6">
    <!-- 모바일 전용 날짜 -->
    {period && <div class="sm:hidden text-xs text-gray-400 mb-2">{period}</div>}

    <div class="bg-white border border-gray-200 rounded-2xl p-5 sm:p-6 relative">
      <!-- 카테고리 태그 (우상단) -->
      <div class="absolute top-4 right-4 flex flex-wrap gap-1.5 justify-end">
        <span class={`px-2 py-0.5 text-xs font-medium rounded ${tagStyle[category] ?? "bg-gray-100 text-gray-600"}`}>
          {category}
        </span>
        {current && (
          <span class="px-2 py-0.5 bg-blue-50 text-accent text-xs font-medium rounded">진행 중</span>
        )}
      </div>

      <!-- 제목 -->
      <h3 class="text-base sm:text-lg font-bold text-gray-900 mb-1 pr-28 leading-snug">{title}</h3>

      <!-- 기관명 -->
      {org && <p class="text-xs text-gray-400 mb-3">{org}</p>}

      <!-- 본문 (MDX body) -->
      <div class="text-sm text-gray-600 leading-relaxed prose prose-sm max-w-none">
        <Content />
      </div>

      {isBlenderUE && (
        <div class="mt-4 flex flex-wrap gap-2">
          <button
            type="button"
            data-modal-open="blender-ue5"
            data-video-id="IpsGFjavhq0"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            개인 프로젝트1 보기
            <span aria-hidden="true">▸</span>
          </button>
          <button
            type="button"
            data-modal-open="blender-ue5"
            data-video-id="5-oH4xFLu-o"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            개인 프로젝트2 보기
            <span aria-hidden="true">▸</span>
          </button>
          <button
            type="button"
            data-modal-open="blender-ue5"
            data-video-id="fr4TIXOXnZw"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            3D 툴 활용 보기
            <span aria-hidden="true">▸</span>
          </button>
        </div>
      )}

      {isAPYE && (
        <div class="mt-4 flex flex-wrap gap-2">
          <button
            type="button"
            data-modal-open="apye"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            활동 영상 보기
            <span aria-hidden="true">▸</span>
          </button>
        </div>
      )}

      {isNationwideWalk && (
        <div class="mt-4 flex flex-wrap gap-2">
          <button
            type="button"
            data-modal-open="nationwide-walk"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            활동 사진 보기
            <span aria-hidden="true">▸</span>
          </button>
        </div>
      )}

      {isHealLab && (
        <div class="mt-4 flex flex-wrap gap-2">
          <button
            type="button"
            data-modal-open="heal-lab"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            연구실 보기
            <span aria-hidden="true">▸</span>
          </button>
        </div>
      )}

      {isOVAL && (
        <div class="mt-4 flex flex-wrap gap-2">
          <button
            type="button"
            data-modal-open="oval"
            data-oval-branch="japan"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            일본 지부
            <span aria-hidden="true">▸</span>
          </button>
          <button
            type="button"
            data-modal-open="oval"
            data-oval-branch="korea"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            한국 지부
            <span aria-hidden="true">▸</span>
          </button>
          <button
            type="button"
            data-modal-open="oval"
            data-oval-branch="china"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            중국 지부
            <span aria-hidden="true">▸</span>
          </button>
        </div>
      )}

      {isHanyangMajor && (
        <div class="mt-4 flex flex-wrap gap-2">
          <button
            type="button"
            data-modal-open="hanyang-major"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer"
          >
            홈페이지 바로가기
            <span aria-hidden="true">▸</span>
          </button>
        </div>
      )}
    </div>
  </div>

</li>
