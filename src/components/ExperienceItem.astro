---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"experience">;
}

const { entry } = Astro.props;
const { title, period, org, description, category, current } = entry.data;
---

<li class="ml-6 group">
  <!-- 타임라인 도트 -->
  <span class="absolute -left-3 flex h-6 w-6 items-center justify-center rounded-full bg-white border-2 border-gray-200">
    <span class={`h-2.5 w-2.5 rounded-full transition-colors ${current ? "bg-accent" : "bg-gray-300 group-hover:bg-accent"}`} />
  </span>

  <!-- 카테고리 태그 + 진행 중 뱃지 -->
  <div class="flex flex-wrap items-center gap-2 mb-1.5">
    <span class="px-2 py-0.5 bg-gray-100 text-xs font-medium text-gray-500 rounded">
      {category}
    </span>
    {current && (
      <span class="px-2 py-0.5 bg-blue-50 text-accent text-xs font-medium rounded">진행 중</span>
    )}
  </div>

  <!-- 항목 정보 -->
  <h3 class="text-base font-semibold text-gray-900 mb-0.5">{title}</h3>
  {period && <time class="text-xs text-gray-400">{period}</time>}
  {org && <p class="text-xs text-gray-500 mt-0.5">{org}</p>}
  {description && <p class="text-xs text-gray-500 mt-0.5">{description}</p>}

  <!-- TODO: PM 관점 어필 포인트 1~2줄 (Phase 3에서 작성) (ROADMAP §2.2 Experience) -->
</li>
