---
// AI 기반 PM 프로젝트 상세 페이지용 — 내일찾기 / 피움 링크 목록 모달 카드 버튼
// 카드형 버튼 2개(가로 배치) → 클릭 시 각 프로젝트의 링크 목록 모달 표시

const project1 = {
  key: "ai-pm-1",
  title: "내일찾기",
  links: [
    { label: "내일찾기 문서 전체 보기", href: "https://app.notion.com/p/2026-396ba86bd6ea8013960ef34f60b3545e?source=copy_link" },
    { label: "프로토타입 체험해보기", href: "https://lynstory.github.io/findtomorrow_prototype_by_Lyn07/" },
    { label: "내일찾기 소개 자료 보기", href: "https://www.figma.com/deck/6cdbt1A95dVXIeVkNeJ8ws/%EB%82%B4%EC%9D%BC%EC%B0%BE%EA%B8%B0-PPT--%EB%B3%91%ED%98%84--%EC%A0%95%EB%A6%B0-?node-id=12-265&t=myafwX12j9yDcqnO-1" },
  ],
};

const project2 = {
  key: "ai-pm-2",
  title: "피움",
  links: [
    { label: "피움 문서 뷰어로 한눈에 전체 보기", href: "https://piwoom-viewer.netlify.app/" },
    { label: "프로토타입 체험해보기", href: "https://piwoom-prototype.netlify.app/" },
    { label: "화면설계서 보기", href: "https://piwoom-screen-design-document.netlify.app/" },
    { label: "와이어프레임", href: "https://piwoom-wireframe.netlify.app/" },
    { label: "프로젝트 소개 자료 보기", href: "https://piwoom-presentation.netlify.app/#s1" },
  ],
};

const projects = [project1, project2];
---

<!-- 카드형 버튼 2개 (가로 나란히) -->
<div class="not-prose grid grid-cols-2 gap-4 my-8">
  <button
    type="button"
    data-modal-open="ai-pm-1"
    class="group flex items-center justify-between gap-3 p-5 sm:p-6 bg-white border border-gray-200 rounded-2xl hover:border-gray-900 hover:shadow-md transition-all cursor-pointer text-left"
  >
    <span class="text-base sm:text-lg font-bold text-gray-900">프로젝트1 보기</span>
    <span aria-hidden="true" class="text-gray-400 group-hover:text-gray-900 transition-colors">▸</span>
  </button>
  <button
    type="button"
    data-modal-open="ai-pm-2"
    class="group flex items-center justify-between gap-3 p-5 sm:p-6 bg-white border border-gray-200 rounded-2xl hover:border-gray-900 hover:shadow-md transition-all cursor-pointer text-left"
  >
    <span class="text-base sm:text-lg font-bold text-gray-900">프로젝트2 보기</span>
    <span aria-hidden="true" class="text-gray-400 group-hover:text-gray-900 transition-colors">▸</span>
  </button>
</div>

<!-- 링크 목록 모달 2개 -->
{projects.map((p) => (
  <dialog
    id={`${p.key}-modal`}
    class="not-prose fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-0 bg-transparent backdrop:bg-black/60 w-[92vw] max-w-md"
    aria-label={`${p.title} 프로젝트 자료`}
  >
    <div class="relative bg-white rounded-2xl p-6 sm:p-8">
      <button
        type="button"
        data-modal-close
        aria-label="닫기"
        class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full bg-white/90 hover:bg-gray-100 text-gray-700 cursor-pointer"
      >✕</button>
      <h3 class="text-lg font-bold text-gray-900 mb-4 pr-8">{p.title}</h3>
      <div class="flex flex-col gap-2">
        {p.links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between gap-2 px-4 py-3 border border-gray-200 rounded-xl hover:bg-gray-50 transition-colors text-sm font-medium text-gray-900"
          >
            {link.label}
            <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>
  </dialog>
))}

<script>
  function wireModal(key: string) {
    const modal = document.getElementById(`${key}-modal`) as HTMLDialogElement | null;
    document.querySelectorAll<HTMLButtonElement>(`[data-modal-open="${key}"]`).forEach(btn => {
      btn.addEventListener('click', () => modal?.showModal());
    });
    modal?.querySelector('[data-modal-close]')?.addEventListener('click', () => modal?.close());
    modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
  }
  wireModal('ai-pm-1');
  wireModal('ai-pm-2');
</script>
