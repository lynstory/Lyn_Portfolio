---
import { projectOrder } from "../lib/projectOrder";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL;

const idx = projectOrder.indexOf(currentSlug as any);
const prevSlug = idx > 0 ? projectOrder[idx - 1] : null;
const nextSlug = idx >= 0 && idx < projectOrder.length - 1 ? projectOrder[idx + 1] : null;

const activeSide = "inline-flex items-center justify-center gap-2 px-4 py-3 border border-gray-200 text-gray-700 text-sm font-medium rounded-lg hover:border-gray-400 hover:text-gray-900 transition-colors";
const disabledSide = "inline-flex items-center justify-center gap-2 px-4 py-3 border border-gray-100 text-gray-300 text-sm font-medium rounded-lg cursor-not-allowed opacity-60";
---

<nav class="border-t border-gray-100 mt-16">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex flex-col gap-3 sm:grid sm:grid-cols-3">
      {prevSlug ? (
        <a href={`${base}projects/${prevSlug}`} class={activeSide}>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          이전 프로젝트
        </a>
      ) : (
        <span class={disabledSide} aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          이전 프로젝트
        </span>
      )}

      <a href={`${base}projects`} class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors">
        전체 프로젝트로 돌아가기
      </a>

      {nextSlug ? (
        <a href={`${base}projects/${nextSlug}`} class={activeSide}>
          다음 프로젝트
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      ) : (
        <span class={disabledSide} aria-hidden="true">
          다음 프로젝트
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </span>
      )}
    </div>
  </div>
</nav>
